# Backend environment variables — copy to .env and fill in values

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/resale-inspector?retryWrites=true&w=majority

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ─── ML Microservice ──────────────────────────────────────────────────────────
ML_SERVICE_URL=http://localhost:8000
